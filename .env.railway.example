# ---- Paste these into Railway → your service → Variables ----
APP_NAME=Abitzu CMS
APP_ENV=production
APP_DEBUG=false
APP_KEY=            # generate with: php artisan key:generate --show  (or let the container make one)
APP_URL=https://YOUR-APP.up.railway.app

# Database — reference the MySQL plugin's URL (Railway substitutes this):
DB_CONNECTION=mysql
DB_URL=${{MySQL.MYSQL_URL}}

# Session/cache use the database/file by default — fine for a small deployment
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database
LOG_CHANNEL=stderr
